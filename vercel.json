{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/panel/:path*",
      "destination": "/api/panel/:path*"
    },
    {
      "source": "/wpanel/:path*",
      "destination": "/api/wpanel/:path*"
    },
    {
      "source": "/Auth/:path*",
      "destination": "/api/Auth/:path*"
    }
  ]
}
