{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/panel/:path*",
      "destination": "/api/panel/:path*"
    },
    {
      "source": "/wpanel/:path*",
      "destination": "/api/wpanel/:path*"
    },
    {
      "source": "/Auth/:path*",
      "destination": "/api/Auth/:path*"
    },
    {
      "source": "/down/:path*",
      "destination": "/api/down/:path*"
    },
    {
      "source": "/install/src/:path*",
      "destination": "https://apibt5.662123.xyz/install/src/:path*"
    },
    {
      "source": "/install/update/:path*",
      "destination": "https://apibt5.662123.xyz/install/update/:path*"
    },
    {
      "source": "/win/panel/:path*.zip",
      "destination": "https://apibt5.662123.xyz/win/panel/:path*.zip"
    }
  ]
}
